# Finance Factors Dashboard - Environment Variables
# Copy this file to .env.local and fill in your API keys

REDIS_URL=redis://default:Sp0fB5UNe0Fi0SyhEhnXxaR4QAr5ci4b@redis-16374.c289.us-west-1-2.ec2.redns.redis-cloud.com:16374

# =============================================================================
# FRED API (Federal Reserve Economic Data)
# =============================================================================
# Get your free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Rate limit: 120 requests per minute
# Data: Housing prices, interest rates, GDP, unemployment, etc.
NEXT_PUBLIC_FRED_API_KEY=d45d9655ab79981088aa17b30a0c741b
NEXT_PUBLIC_FRED_BASE_URL=https://api.stlouisfed.org/fred

# =============================================================================
# BLS API (Bureau of Labor Statistics)
# =============================================================================
# Get your free API key at: https://www.bls.gov/developers/api_signature_v2.htm
# Without key: 25 requests/day, 10 years/query
# With key: 500 requests/day, 20 years/query
# Data: Employment, wages, inflation, labor statistics
NEXT_PUBLIC_BLS_API_KEY=81277313b0e141148d59fa83125510de
NEXT_PUBLIC_BLS_BASE_URL=https://api.bls.gov/publicAPI/v2

# =============================================================================
# Census Bureau API
# =============================================================================
# API key is optional but recommended for reliability
# Get your free API key at: https://api.census.gov/data/key_signup.html
# Rate limit: No strict limits for public use
# Data: Demographics, housing, income, population statistics
NEXT_PUBLIC_CENSUS_API_KEY=e0d9fd6f239294efa560fd5b8d382d6978439e7b
NEXT_PUBLIC_CENSUS_BASE_URL=https://api.census.gov/data

# =============================================================================
# Alpha Vantage API (Optional - for additional economic indicators)
# =============================================================================
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/minute
# Premium plans available for higher limits
# Data: Economic indicators, stock data, forex
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=IIHJAF2UJ4PS0J8Y
NEXT_PUBLIC_ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# =============================================================================
# Server-side API Keys (Secure - for Vercel Functions)
# =============================================================================
# These are used by the API proxy and are NOT exposed to the browser
FRED_API_KEY=d45d9655ab79981088aa17b30a0c741b
BLS_API_KEY=81277313b0e141148d59fa83125510de
CENSUS_API_KEY=e0d9fd6f239294efa560fd5b8d382d6978439e7b
ALPHA_VANTAGE_API_KEY=IIHJAF2UJ4PS0J8Y

# =============================================================================
# Application Configuration
# =============================================================================
# Default data source: 'historical' or 'live-api'
# Use 'historical' for GitHub Pages deployment to avoid CORS issues
# Use 'live-api' for server deployments with API proxy (Vercel, Netlify, etc.)
NEXT_PUBLIC_DEFAULT_DATA_SOURCE=live-api

# Enable API proxy to solve CORS issues
NEXT_PUBLIC_USE_API_PROXY=true

# Enable debug logging for API calls
NEXT_PUBLIC_DEBUG_API=false

# Cache duration in minutes
NEXT_PUBLIC_CACHE_DURATION=30

# =============================================================================
# API Priority Configuration
# =============================================================================
# Which APIs to use as primary/fallback for each data type
# Format: primary,fallback1,fallback2

# House prices: FRED (primary), Census (fallback)
NEXT_PUBLIC_HOUSE_PRICES_APIS=FRED,CENSUS

# Income data: BLS (primary), Census (fallback)
NEXT_PUBLIC_INCOME_APIS=BLS,CENSUS

# Economic indicators: FRED (primary), Alpha Vantage (fallback)
NEXT_PUBLIC_ECONOMIC_APIS=FRED,ALPHA_VANTAGE

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Override default rate limits (requests per minute)
NEXT_PUBLIC_FRED_RATE_LIMIT=120
NEXT_PUBLIC_BLS_RATE_LIMIT=10
NEXT_PUBLIC_CENSUS_RATE_LIMIT=100
NEXT_PUBLIC_ALPHA_VANTAGE_RATE_LIMIT=5

# =============================================================================
# Development/Testing Configuration
# =============================================================================
# Force use of mock data even when API keys are present
NEXT_PUBLIC_FORCE_MOCK_DATA=false

# API health check interval in minutes
NEXT_PUBLIC_HEALTH_CHECK_INTERVAL=60

# Enable API response caching
NEXT_PUBLIC_ENABLE_CACHING=true

# =============================================================================
# GitHub Pages Deployment
# =============================================================================
# Base path for GitHub Pages deployment (if deploying to a subdirectory)
# Example: /finance-factors for https://username.github.io/finance-factors
NEXT_PUBLIC_BASE_PATH=

# Asset prefix for GitHub Pages
NEXT_PUBLIC_ASSET_PREFIX=

# =============================================================================
# Analytics and Monitoring (Optional)
# =============================================================================
# Google Analytics tracking ID
NEXT_PUBLIC_GA_TRACKING_ID=

# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# API Key Setup Instructions
# =============================================================================

# 1. FRED API Key (Recommended - Free):
#    - Visit: https://fred.stlouisfed.org/docs/api/api_key.html
#    - Create a free account
#    - Request an API key
#    - Add to NEXT_PUBLIC_FRED_API_KEY above

# 2. BLS API Key (Optional but recommended):
#    - Visit: https://www.bls.gov/developers/api_signature_v2.htm
#    - Register for a free account
#    - Request an API key
#    - Add to NEXT_PUBLIC_BLS_API_KEY above

# 3. Census Bureau API Key (Optional):
#    - Visit: https://api.census.gov/data/key_signup.html
#    - Request a free API key
#    - Add to NEXT_PUBLIC_CENSUS_API_KEY above

# 4. Alpha Vantage API Key (Optional):
#    - Visit: https://www.alphavantage.co/support/#api-key
#    - Sign up for a free account
#    - Get your API key
#    - Add to NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY above

# =============================================================================
# Quick Start
# =============================================================================
# For a quick start with the most important data:
# 1. Get a FRED API key (free, 120 requests/minute)
# 2. Set NEXT_PUBLIC_FRED_API_KEY
# 3. Set NEXT_PUBLIC_DEFAULT_DATA_SOURCE=live-api
# 4. Restart your development server

# This will give you access to:
# - House price indices
# - Interest rates
# - Unemployment rates
# - GDP data
# - And many other economic indicators
