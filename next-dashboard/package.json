{
  "name": "next-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy": "echo 'Deployment is handled automatically by GitHub Actions. Push to main branch to deploy to Vercel.'",
    "deploy:manual": "./deploy-vercel.sh",
    "setup:vercel": "./setup-vercel-env.sh",
    "verify:vercel": "./verify-vercel-setup.sh",
    "dev:vercel": "vercel dev",
    "vercel:login": "vercel login",
    "vercel:env": "vercel env ls",
    "vercel:logs": "vercel logs",
    "test:apis": "node scripts/test-apis.js",
    "test:health": "node scripts/test-health-checks.js",
    "test:health:verbose": "node scripts/test-health-checks.js --verbose",
    "test:health:production": "TEST_BASE_URL=https://finance-factors.vercel.app node scripts/test-health-checks.js",
    "test:parallel": "node scripts/test-parallel-fetching.js",
    "test:parallel:full": "node scripts/test-parallel-fetching.js --full",
    "test:redis": "node test-redis-connection.js",
    "test:redis:caching": "node test-redis-caching.js",
    "test:redis:api": "node test-api-caching.js",
    "test:redis:24h": "node test-redis-24hour-caching.js",
    "test:dual-data-source": "node scripts/test-dual-data-source.js",
    "verify:cache-config": "node verify-cache-config.js",
    "db:cleanup": "node scripts/cleanup-connections.js",
    "db:health": "curl -s http://localhost:3000/api/db-health | jq .",
    "db:monitor": "curl -s 'http://localhost:3000/api/db-health?monitoring=true' | jq .",
    "check:deployment": "curl -s https://$(vercel ls | grep finance-factors | head -1 | awk '{print $2}')/api/proxy/health || echo 'Deployment not found or not ready'",
    "health:local": "curl -s http://localhost:3000/api/health | jq .",
    "health:production": "curl -s https://finance-factors.vercel.app/api/health | jq .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:test": "node scripts/test-database.js",
    "performance:test": "node scripts/test-performance.js",
    "performance:monitor": "curl -s http://localhost:3000/api/performance | jq .",
    "cache:clear": "curl -X POST http://localhost:3000/api/cache/clear",
    "graphql:playground": "open http://localhost:3000/api/graphql"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@apollo/server": "^5.4.0",
    "@as-integrations/next": "^4.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@types/pg": "^8.18.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.138",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crossfilter2": "^1.5.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.1",
    "graphql-tag": "^2.12.6",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-resizable-panels": "^4.7.3",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
